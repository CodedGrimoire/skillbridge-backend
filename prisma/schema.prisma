generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum Role {
  USER
  ADMIN
}

model User {
  id         String       @id @default(uuid())
  name       String
  email      String       @unique
  password   String
  role       Role         @default(USER)
  createdAt  DateTime     @default(now())
  updatedAt  DateTime     @updatedAt
  resumes    Resume[]
  analyses   Analysis[]
  userSkills UserSkill[]
}

model Resume {
  id            String     @id @default(uuid())
  user          User       @relation(fields: [userId], references: [id])
  userId        String
  fileName      String
  fileUrl       String
  extractedText String?
  createdAt     DateTime   @default(now())
  analyses      Analysis[]

  @@index([userId])
}

model Skill {
  id        String       @id @default(uuid())
  name      String       @unique
  category  String?
  createdAt DateTime     @default(now())
  userSkills UserSkill[]
  roleSkills RoleSkill[]
  resources  LearningResource[]
}

model UserSkill {
  id              String @id @default(uuid())
  user            User   @relation(fields: [userId], references: [id])
  userId          String
  skill           Skill  @relation(fields: [skillId], references: [id])
  skillId         String
  confidenceScore Float?

  @@unique([userId, skillId])
  @@index([skillId])
}

model JobRole {
  id          String      @id @default(uuid())
  title       String
  description String?
  createdAt   DateTime    @default(now())
  roleSkills  RoleSkill[]
  analyses    Analysis[]
  nextPaths   CareerPath[] @relation("FromRole")
  prevPaths   CareerPath[] @relation("ToRole")
}

model RoleSkill {
  id              String  @id @default(uuid())
  role            JobRole @relation(fields: [roleId], references: [id])
  roleId          String
  skill           Skill   @relation(fields: [skillId], references: [id])
  skillId         String
  importanceLevel Int?

  @@unique([roleId, skillId])
  @@index([skillId])
}

model Analysis {
  id               String    @id @default(uuid())
  user             User      @relation(fields: [userId], references: [id])
  userId           String
  resume           Resume?   @relation(fields: [resumeId], references: [id])
  resumeId         String?
  role             JobRole?  @relation(fields: [roleId], references: [id])
  roleId           String?
  matchScore       Float?
  matchedSkills    Json?
  missingSkills    Json?
  aiRecommendations String?
  createdAt        DateTime  @default(now())

  @@index([userId])
  @@index([resumeId])
  @@index([roleId])
}

model LearningResource {
  id        String   @id @default(uuid())
  skill     Skill    @relation(fields: [skillId], references: [id])
  skillId   String
  title     String
  url       String
  type      String?
  createdAt DateTime @default(now())

  @@index([skillId])
}

model Job {
  id          String   @id @default(uuid())
  title       String
  company     String
  location    String
  description String?
  skills      Json
  salary      String?
  source      String?
  datePosted  DateTime?
  createdAt   DateTime @default(now())

  @@index([title])
  @@index([company])
}

model CareerPath {
  id         String   @id @default(uuid())
  fromRole   JobRole  @relation("FromRole", fields: [fromRoleId], references: [id])
  fromRoleId String
  toRole     JobRole  @relation("ToRole", fields: [toRoleId], references: [id])
  toRoleId   String
  createdAt  DateTime @default(now())

  @@index([fromRoleId])
  @@index([toRoleId])
}
